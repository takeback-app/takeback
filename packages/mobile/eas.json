{
  "cli": {
    "version": ">= 0.48.0"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "buildConfiguration": "Debug",
        "resourceClass": "m-medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "staging",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "API_URL": "https://takeback-staging.herokuapp.com/"
      }
    },
    "production": {
      "channel": "prod",
      "env": {
        "API_URL": "https://takebackapi.herokuapp.com/"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "devops@takeback.app.br",
        "ascAppId": "1617475702",
        "appleTeamId": "787LSF89G4"
      }
    }
  }
}
