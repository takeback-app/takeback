{
  "name": "@takeback/api",
  "version": "1.5.0",
  "description": "Default api of the takeback application",
  "license": "ISC",
  "scripts": {
    "build": "tsc --target ES6 --experimentalDecorators --emitDecoratorMetadata",
    "dev": "nodemon src/server.ts",
    "start": "node -r newrelic ./dist/src/server.js",
    "typeorm": "node --require ts-node/register ./node_modules/typeorm/cli.js",
    "generate:cache": "node ./dist/src/commands/GenerateTransactionsCache.js",
    "migration:generate": "npm run typeorm migration:generate -- -n",
    "migration:run": "npm run typeorm migration:run",
    "migration:revert": "npm run typeorm migration:revert",
    "test": "node -r ts-node/register bin/test.ts",
    "cover": "nyc --reporter=lcov --reporter=text-summary yarn test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.304.0",
    "@prisma/client": "^4.15.0",
    "@types/redis": "^4.0.11",
    "axios": "^0.23.0",
    "bcrypt": "^5.0.1",
    "body-parser": "^1.18.1",
    "brazilian-values": "^0.12.0",
    "cli-progress": "^3.12.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.1",
    "dotenv": "^10.0.0",
    "excel4node": "^1.7.2",
    "expo-server-sdk": "^3.7.0",
    "express": "^4.15.4",
    "express-async-errors": "^3.1.1",
    "handlebars": "^4.7.7",
    "ioredis": "^5.3.1",
    "jsonwebtoken": "^8.5.1",
    "knex": "^2.4.2",
    "knex-paginate": "^3.1.1",
    "luxon": "^3.3.0",
    "multer": "^1.4.4",
    "multer-s3": "^2.10.0",
    "newrelic": "^9.15.0",
    "node-cron": "^3.0.0",
    "nodemailer": "^6.6.5",
    "pdfmake": "0.2.4",
    "pg": "^8.10.0",
    "pino": "^8.11.0",
    "pino-caller": "^3.4.0",
    "reflect-metadata": "^0.1.10",
    "typeorm": "0.2.37",
    "uuid": "^8.3.2",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@japa/api-client": "^1.4.4",
    "@japa/assert": "^1.4.1",
    "@japa/run-failed-tests": "^1.1.1",
    "@japa/runner": "^2.5.1",
    "@japa/spec-reporter": "^1.3.3",
    "@swc/cli": "^0.1.62",
    "@swc/core": "^1.3.37",
    "@types/bcrypt": "^5.0.0",
    "@types/cli-progress": "^3.11.0",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13",
    "@types/jsonwebtoken": "^8.5.5",
    "@types/luxon": "^3.3.0",
    "@types/multer": "^1.4.7",
    "@types/multer-s3": "^2.7.11",
    "@types/node": "^18.14.6",
    "@types/node-cron": "^3.0.1",
    "@types/nodemailer": "^6.4.4",
    "@types/pdfmake": "^0.1.21",
    "@types/pg": "^8.6.6",
    "@types/uuid": "^8.3.3",
    "@typescript-eslint/eslint-plugin": "^5.8.1",
    "@typescript-eslint/parser": "^5.9.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-promise": "^4.2.1",
    "execa": "^7.0.0",
    "nodemon": "^2.0.22",
    "nyc": "^15.1.0",
    "prettier": "^2.5.1",
    "prisma": "^4.15.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.8.4"
  }
}
